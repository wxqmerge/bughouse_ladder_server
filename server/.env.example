# ============================================
# BUGHOUSE CHESS LADDER SERVER - ENVIRONMENT CONFIGURATION
# ============================================
#
# IMPORTANT: Copy this file to .env and fill in the values below.
# NEVER commit the .env file to version control!
#
# ============================================

# ============================================
# SERVER CONFIGURATION
# ============================================

# Server port (uses TCP/HTTP - NOT UDP)
PORT=3000

# Node environment (development or production)
NODE_ENV=development

# ============================================
# SECURITY - OPTIONAL PROTECTION
# =============================================

# CORS Origins - Your frontend domain(s), comma-separated
# Examples:
#   Development: http://localhost:5173
#   Production: https://your-domain.com
CORS_ORIGINS=http://localhost:5173

# Admin API Key - Protects admin endpoints (/api/admin/*)
# Requests must include header: X-API-Key: <this-value>
# Delete or empty this line to disable admin protection (local mode)
# Generate secure key with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=dev-admin-key-change-in-production

# User API Key - Protects write operations (PUT/DELETE on ladder, POST on games)
# Users without a valid key can only VIEW the table (read-only)
# Users with a valid key can edit, enter games, and save
# Delete or empty this line to disable user auth (local/dev mode)
USER_API_KEY=change-this-to-a-random-key

# ============================================
# DATA CONFIGURATION
# ============================================

# Path to ladder data file
TAB_FILE_PATH=./data/ladder.tab
