# ============================================
# BUGHOUSE CHESS LADDER SERVER - ENVIRONMENT CONFIGURATION
# ============================================
#
# IMPORTANT: Copy this file to .env and fill in the values below.
# NEVER commit the .env file to version control!
#
# ============================================

# ============================================
# SERVER CONFIGURATION
# ============================================

# Server port
PORT=3000

# Node environment (development or production)
NODE_ENV=development

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Backend API URL (for frontend to connect to backend)
VITE_API_URL=http://localhost:3000

# ============================================
# SECURITY - REQUIRED FOR PRODUCTION
# ============================================

# JWT Secret for signing authentication tokens
# Generate a secure secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# EXAMPLE: JWT_SECRET=a1b2c3d4e5f6...
JWT_SECRET=

# CORS Origin - Your frontend domain (required for production)
# Examples:
#   Development: http://localhost:5173
#   Production: https://your-domain.com
CORS_ORIGIN=http://localhost:5173

# ============================================
# ADMIN CREDENTIALS - REQUIRED FOR PRODUCTION
# ============================================

# Default admin username
ADMIN_USERNAME=admin

# Default admin password (will be hashed automatically)
# Use a strong password in production!
ADMIN_PASSWORD=

# ============================================
# DATA CONFIGURATION
# ============================================

# Path to ladder data file
TAB_FILE_PATH=./data/ladder.tab
