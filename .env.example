# ============================================
# BUGHOUSE CHESS LADDER SERVER - ENVIRONMENT CONFIGURATION
# ============================================
#
# IMPORTANT: Copy this file to .env and fill in the values below.
# NEVER commit the .env file to version control!
#
# ============================================

# ============================================
# SERVER CONFIGURATION
# ============================================

# Server port
PORT=3000

# Node environment (development or production)
NODE_ENV=development

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Backend API URL (for frontend to connect to backend)
VITE_API_URL=http://localhost:3000

# ============================================
# SECURITY - OPTIONAL PROTECTION
# ============================================

# CORS Origin - Your frontend domain
# Examples:
#   Development: http://localhost:5173
#   Production: https://your-domain.com
CORS_ORIGIN=http://localhost:5173

# Admin API Key - Optional protection for admin endpoints
# If set, requests to /api/admin/* must include header:
#   X-API-Key: <this-value>
# Leave empty for unrestricted access (local/dev mode)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=

# ============================================
# DATA CONFIGURATION
# ============================================

# Path to ladder data file
TAB_FILE_PATH=./data/ladder.tab
